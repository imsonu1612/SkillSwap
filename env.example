# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/skillswap
# For production, use MongoDB Atlas or your cloud MongoDB instance
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/skillswap

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Server Configuration
PORT=5000
NODE_ENV=development

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:3000

# Frontend realtime socket settings
# In production, set REACT_APP_SOCKET_URL only if you deploy a websocket-capable backend.
# If omitted, realtime socket connects are disabled by default in production.
# REACT_APP_SOCKET_URL=https://your-socket-backend.example.com
# REACT_APP_ENABLE_SOCKET=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100 